    def test_time_feature_dataset_emits_gap_and_elapsed_channels(self) -> None:
        cfg = LOBConfig()
        cfg.apply_overrides(levels=1, history_len=4, use_time_features=True)
        params = np.arange(18, dtype=np.float32).reshape(9, 2)
        mids = np.linspace(1.0, 2.0, 9, dtype=np.float32)
        time_features = np.stack(
            [
                np.array([0.0, 0.0, 0.7, 0.0, 1.1, 0.4, 0.0, 0.2, 0.3], dtype=np.float32),
                np.array([0.0, 0.2, 0.5, 0.0, 0.4, 0.8, 0.0, 0.1, 0.4], dtype=np.float32),
            ],
            axis=1,
        )
        ds = WindowedLOBParamsDataset(
            params=params,
            mids=mids,
            history_len=4,
            future_horizon=2,
            time_features=time_features,
            time_gap_scale=1.0,
            time_feature_source="timestamps",
        )
        hist, tgt, fut, meta = ds[0]
        self.assertEqual(hist.shape[-1], params.shape[1] + 2)
        self.assertEqual(tuple(ds.future_time_features(int(meta["t"]), 2).shape), (2, 2))
        self.assertEqual(float(hist[0, -1]), 0.0)

    def test_legacy_gap_only_dataset_keeps_single_time_channel(self) -> None:
        cfg = LOBConfig()
        cfg.apply_overrides(levels=1, history_len=4, use_time_gaps=True, use_time_features=False)
        params = np.arange(18, dtype=np.float32).reshape(9, 2)
        mids = np.linspace(1.0, 2.0, 9, dtype=np.float32)
        time_gap_features = np.array([[0.0], [0.1], [0.2], [0.0], [0.3], [0.4], [0.0], [0.5], [0.6]], dtype=np.float32)
        ds = WindowedLOBParamsDataset(
            params=params,
            mids=mids,
            history_len=4,
            future_horizon=2,
            time_gap_features=time_gap_features,
            time_gap_scale=1.0,
