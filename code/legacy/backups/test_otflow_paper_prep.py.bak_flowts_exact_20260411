    def test_schedule_grids_are_monotone_for_implemented_fixed_schedules(self) -> None:
        for key in ("uniform", "late_power_2", "late_power_3", "early_biased_control"):
            grid = build_schedule_grid(key, 10)
            self.assertIsNotNone(grid)
            assert grid is not None
            self.assertEqual(grid[0], 0.0)
            self.assertEqual(grid[-1], 1.0)
            self.assertTrue(all(grid[idx] < grid[idx + 1] for idx in range(len(grid) - 1)))

    def test_imported_schedule_grids_are_monotone(self) -> None:
        for key in ("ays", "gits", "ots"):
            for nfe in (10, 12, 16):
                grid = build_schedule_grid(key, nfe)
                self.assertIsNotNone(grid)
                assert grid is not None
                self.assertEqual(grid[0], 0.0)
                self.assertEqual(grid[-1], 1.0)
                self.assertEqual(len(grid), nfe + 1)
                self.assertTrue(all(grid[idx] < grid[idx + 1] for idx in range(len(grid) - 1)))

    def test_registry_contains_only_tvdp_schedule_as_main_method(self) -> None:
        schedule_specs = {spec.key: spec for spec in paper_schedule_specs()}
        solver_specs = {spec.key: spec for spec in paper_solver_specs()}
        schedule_keys = set(schedule_specs)
        solver_keys = set(solver_specs)
        self.assertIn("tvdp_schedule", schedule_keys)
        self.assertNotIn("tvdp", schedule_keys)
        self.assertNotIn("legacy_hybrid_signal", schedule_keys)
        self.assertNotIn("hybrid_signal", schedule_keys)
        self.assertEqual({"euler", "heun", "midpoint_rk2", "dopri5", "rk45", "dpmpp2m"}, solver_keys)
        for schedule_key in ("ays", "gits", "ots"):
            self.assertEqual(schedule_specs[schedule_key].solver_scope, "euler_only_main_matrix")
        for solver_key in ("heun", "midpoint_rk2", "dopri5", "rk45"):
            self.assertEqual(solver_specs[solver_key].main_matrix_scope, "all_nonmapped_schedules")
        self.assertEqual(solver_specs["dpmpp2m"].order, int(paper_solver_order_p("dpmpp2m")))

