    def test_lob_audit_infers_timestamp_unit_and_segment_breaks(self) -> None:
        with tempfile.TemporaryDirectory() as tmpdir:
            path = Path(tmpdir) / "cryptos_like.npz"
            mids = np.linspace(100.0, 103.0, 64, dtype=np.float32)
            timestamps = []
            current = 1_575_158_405_798_000
            for idx in range(64):
                if idx == 32:
                    current += 120_000_000
                timestamps.append(current)
                current += 1_000_000
            np.savez(path, mids=mids, timestamps=np.asarray(timestamps, dtype=np.int64))
            payload = audit_lob_dataset("cryptos", str(path))
            self.assertAlmostEqual(payload["frequency_seconds"], 1.0, places=3)
            self.assertEqual(payload["regularity"]["time_unit"], "microseconds")
            self.assertGreaterEqual(payload["regularity"]["session_breaks"], 1)

