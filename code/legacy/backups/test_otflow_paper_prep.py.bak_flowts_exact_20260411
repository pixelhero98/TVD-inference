        self.assertEqual(hist.shape[-1], params.shape[1] + 1)
        self.assertEqual(tuple(ds.future_time_features(int(meta["t"]), 2).shape), (2, 1))
        self.assertEqual(tuple(ds.future_time_gap_features(int(meta["t"]), 2).shape), (2, 1))

