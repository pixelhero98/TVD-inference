def _parse_csv(text: str) -> List[str]:
    return [part.strip() for part in str(text).split(",") if part.strip()]


def _parse_ints(text: str) -> List[int]:
    return [int(part.strip()) for part in _parse_csv(text)]


def _parse_datasets(text: str) -> List[str]:
    datasets = _parse_csv(text)
    unknown = [name for name in datasets if name not in CANONICAL_ALLOWED_LOB_PAPER_DATASETS]
    if unknown:
        raise ValueError(f"Unknown conditional-generation datasets: {unknown}")
    return datasets


def _parse_ordered_names(text: str, *, allowed: Sequence[str]) -> List[str]:
    names = [str(name) for name in _parse_csv(text)]
    allowed_names = {str(name) for name in allowed}
    invalid = [name for name in names if name not in allowed_names]
    if invalid:
        raise ValueError(f"Unknown names: {invalid}. Allowed: {list(allowed_names)}")
    deduped: List[str] = []
    for name in names:
        if name not in deduped:
            deduped.append(name)
    return deduped


