        "late_power_2": "Late-power-2",
        "late_power_3": "Late-power-3",
        "early_biased_control": "Early-biased control",
        "ays": "AYS",
        "gits": "GITS",
        "ots": "OTS",
        TVDP_SCHEDULE_KEY: "TVD-p schedule",
        "heun": "Heun / RK2",
        "midpoint_rk2": "Midpoint RK2",
        "dopri5": "Dopri5 / Dormand-Prince",
        "rk45": "RK45 / Runge-Kutta45",
        "dpmpp2m": "DPM++2M",
    }


def _solver_eval_multiplier(solver_key: str) -> int:
    key = str(solver_key)
    if key in {"euler", "dpmpp2m"}:
        return 1
    if key in {"heun", "midpoint_rk2"}:
        return 2
    if key in {"dopri5", "rk45"}:
        return 6
    raise ValueError(f"Unsupported solver_key={solver_key}")


def _solver_macro_steps(solver_key: str, target_nfe: int) -> int:
    if str(solver_key) in {"heun", "midpoint_rk2"}:
        if int(target_nfe) % 2 != 0:
            raise ValueError(f"{solver_key} requires an even target_nfe, got {target_nfe}")
        return int(target_nfe) // 2
    multiplier = int(_solver_eval_multiplier(str(solver_key)))
    if multiplier == 1:
        return int(target_nfe)
    return max(1, int(round(float(target_nfe) / float(multiplier))))


def _solver_exact_nfe_peer(solver_key: str, target_nfe: int) -> bool:
    macro_steps = _solver_macro_steps(str(solver_key), int(target_nfe))
    realized = int(macro_steps) * int(_solver_eval_multiplier(str(solver_key)))
    return realized == int(target_nfe)


def _solver_experiment_scope(solver_key: str) -> str:
    return "solver_transfer" if str(solver_key) in TRANSFER_SOLVER_ORDER else "main"


def _solver_order_p(solver_key: str) -> float:
    key = str(solver_key)
    if key == "euler":
        return 1.0
    if key in {"heun", "midpoint_rk2", "dpmpp2m"}:
        return 2.0
    if key in {"dopri5", "rk45"}:
        return 5.0
    raise ValueError(f"Unsupported solver for TVD-p order mapping: {solver_key}")


def _resolved_tvdp_reference_macro_steps(requested_macro_steps: int, runtime_nfe: int) -> int:
    requested = int(requested_macro_steps)
    if requested > 0:
        return requested
    return max(32, 4 * int(runtime_nfe))


def _tvdp_row_signature(
    *,
    signal_trace_key: str,
    signal_family_name: str,
    quantization_mode: str,
    reference_macro_steps: int,
) -> str:
    return (
        f"{_TVDP_ROW_SIGNATURE_VERSION}:"
        f"{str(signal_family_name).strip()}:"
        f"{str(signal_trace_key).strip()}:"
        f"{str(quantization_mode).strip()}:"
        f"{int(reference_macro_steps)}"
    )


def _schedule_experiment_scope(solver_key: str, schedule_name: str) -> str:
    solver_scope = _solver_experiment_scope(str(solver_key))
    if solver_scope == "solver_transfer":
        return "solver_transfer"
    return "main"


def _schedule_allowed_for_solver(solver_key: str, schedule_name: str) -> bool:
    if str(schedule_name) in EULER_ONLY_MAIN_MATRIX_SCHEDULES and str(solver_key) != "euler":
        return False
    return True


def _schedule_comparison_role(solver_key: str, schedule_name: str, base_role: str) -> str:
    scope = _schedule_experiment_scope(str(solver_key), str(schedule_name))
    if scope == "solver_transfer":
        return "solver_transfer_case"
    if str(schedule_name) == TVDP_SCHEDULE_KEY:
        return "paper_method"
    return str(base_role)


def _grid_kind_for_schedule(schedule_name: str) -> str:
    schedule_name = str(schedule_name)
    if str(schedule_name) == "uniform":
        return "uniform_schedule"
    if str(schedule_name) == TVDP_SCHEDULE_KEY:
        return "signal_schedule"
    if str(schedule_name) in {"ays", "gits", "ots"}:
        return "published_fixed_schedule"
    return "generic_fixed_schedule"


def _paper_method_role_for_schedule(schedule_name: str) -> str:
    if str(schedule_name) == TVDP_SCHEDULE_KEY:
        return "method"
    return "baseline"


def _schedule_paper_method_role(solver_key: str, schedule_name: str) -> str:
    scope = _schedule_experiment_scope(str(solver_key), str(schedule_name))
    if scope == "solver_transfer":
        return "solver_transfer"
    return _paper_method_role_for_schedule(str(schedule_name))


def _build_schedule_time_grid(
    *,
    solver_key: str,
    schedule_name: str,
    macro_steps: int,
    calibration: Optional[Mapping[str, Any]],
) -> Tuple[Tuple[float, ...], Dict[str, Any]]:
    schedule_name = str(schedule_name)
    if str(schedule_name) == "uniform":
        grid = build_schedule_grid("uniform", int(macro_steps))
        if grid is None:
            raise ValueError(f"Unable to build grid for schedule={schedule_name}")
        return tuple(float(x) for x in grid), {}
    if str(schedule_name) == TVDP_SCHEDULE_KEY:
        if calibration is None:
            raise ValueError("tvdp_schedule requires solver-specific calibration")
        details = tvdp_schedule_details(
            calibration,
            macro_steps=int(macro_steps),
            delta=float(_TVDP_DELTA),
            solver_order=float(_solver_order_p(str(solver_key))),
            signal_trace_key=str(_TVDP_SIGNAL_TRACE_KEY),
        )
        return (
            tuple(float(x) for x in details["time_grid"]),
            {
                "signal_trace_key": str(_TVDP_SIGNAL_TRACE_KEY),
                "tvdp_delta": float(_TVDP_DELTA),
                "tvdp_solver_order": float(_solver_order_p(str(solver_key))),
                "tvdp_signal_normalized": True,
                "tvdp_quantization_mode": str(details["quantization_mode"]),
                "tvdp_reference_macro_steps": int(details["reference_macro_steps"]),
                "tvdp_reference_time_grid": [float(x) for x in details["reference_time_grid"]],
                "tvdp_reference_time_alignment": str(details["reference_time_alignment"]),
                "tvdp_paper_indices": [int(x) for x in details["paper_indices"]],
                "tvdp_paper_time_grid": [float(x) for x in details["paper_time_grid"]],
                "tvdp_paper_duplicate_count": int(details["paper_duplicate_count"]),
                "paper_discrete_reference": dict(details["paper_discrete_reference"]),
                "row_signature": _tvdp_row_signature(
                    signal_trace_key=str(_TVDP_SIGNAL_TRACE_KEY),
                    signal_family_name=str(_TVDP_SIGNAL_FAMILY_NAME),
                    quantization_mode=str(details["quantization_mode"]),
                    reference_macro_steps=int(details["reference_macro_steps"]),
                ),
            },
        )
    grid = build_schedule_grid(str(schedule_name), int(macro_steps))
    if grid is None:
        raise ValueError(f"Unable to build grid for schedule={schedule_name}")
    return tuple(float(x) for x in grid), {}


def _matrix_spec(
    *,
    dataset: str,
    field_network_type: str,
    checkpoint_id: str,
    solver_key: str,
    schedule_name: str,
    target_nfe: int,
    calibration: Optional[Mapping[str, Any]],
) -> Dict[str, Any]:
    canonical_name = str(schedule_name)
    macro_steps = _solver_macro_steps(str(solver_key), int(target_nfe))
    time_grid, tvdp_metadata = _build_schedule_time_grid(
        solver_key=str(solver_key),
        schedule_name=str(canonical_name),
        macro_steps=int(macro_steps),
        calibration=calibration,
    )
    signal_family_name = None
    signal_validation = None
    smooth_window = None
    temper_alpha = None
    uniform_floor = None
    if str(canonical_name) == TVDP_SCHEDULE_KEY:
        signal_family_name = _TVDP_SIGNAL_FAMILY_NAME
        signal_validation = signal_validation_spearman(calibration, str(_TVDP_SIGNAL_TRACE_KEY)) if calibration is not None else None
        uniform_floor = float(_TVDP_DELTA)
    spec = _make_base_spec(
        dataset=str(dataset),
        field_network_type=str(field_network_type),
        solver_name=str(SOLVER_RUNTIME_NAMES[str(solver_key)]),
        schedule_name=str(canonical_name),
        schedule_display_name=str(SCHEDULE_DISPLAY_NAMES[str(canonical_name)]),
        target_nfe=int(target_nfe),
        runtime_nfe=int(macro_steps),
        time_grid=time_grid,
        comparison_role=_schedule_comparison_role(str(solver_key), str(canonical_name), "schedule_matrix"),
        paper_method_role=_schedule_paper_method_role(str(solver_key), str(canonical_name)),
        exact_nfe_peer=_solver_exact_nfe_peer(str(solver_key), int(target_nfe)),
        row_group=str(SOLVER_DISPLAY_NAMES[str(solver_key)]),
        grid_kind=_grid_kind_for_schedule(str(canonical_name)),
        selection_group="schedule_matrix",
        signal_family_name=signal_family_name,
        signal_validation_spearman=signal_validation,
        smooth_window=smooth_window,
        temper_alpha=temper_alpha,
        uniform_floor=uniform_floor,
    )
    spec.update(
        {
            "checkpoint_id": str(checkpoint_id),
            "solver_key": str(solver_key),
            "macro_steps": int(macro_steps),
            "experiment_scope": _schedule_experiment_scope(str(solver_key), str(schedule_name)),
        }
    )
    spec.update(tvdp_metadata)
    return spec


def _build_schedule_matrix_specs(
    *,
    dataset: str,
    field_network_type: str,
    checkpoint_id: str,
    target_nfe: int,
    solver_names: Sequence[str],
    schedule_names: Sequence[str],
    calibrations: Mapping[str, Mapping[str, Any]],
) -> List[Dict[str, Any]]:
    specs: List[Dict[str, Any]] = []
    for solver_key in solver_names:
        calibration = calibrations.get(str(solver_key))
        for schedule_name in schedule_names:
            if not _schedule_allowed_for_solver(str(solver_key), str(schedule_name)):
                continue
            schedule_calibration = calibration if str(schedule_name) == TVDP_SCHEDULE_KEY else None
            specs.append(
                _matrix_spec(
                    dataset=str(dataset),
                    field_network_type=str(field_network_type),
                    checkpoint_id=str(checkpoint_id),
                    solver_key=str(solver_key),
                    schedule_name=str(schedule_name),
                    target_nfe=int(target_nfe),
                    calibration=schedule_calibration,
                )
            )
    return specs


