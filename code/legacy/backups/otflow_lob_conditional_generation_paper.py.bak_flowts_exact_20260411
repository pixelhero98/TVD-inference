    save_json(payload, str(out_root / "lob_backbone_training_summary.json"))
    return payload


def run_lob_paper(cli_args: argparse.Namespace) -> Dict[str, Any]:
    if not bool(cli_args.allow_execute):
        return run_lob_prep(cli_args)

    out_root = Path(str(cli_args.out_root)).resolve()
    out_root.mkdir(parents=True, exist_ok=True)
    datasets = _parse_datasets(str(cli_args.datasets))
    resolved_future_block_lens = [
        int(
            int(cli_args.future_block_len)
            if int(getattr(cli_args, "future_block_len", 0)) > 0
            else experiment_plan_by_key()[str(dataset)].future_block_len
        )
        for dataset in datasets
    ]
    target_nfe_values = _parse_ints(str(cli_args.target_nfe_values))
    solver_names = _parse_ordered_names(str(cli_args.solver_names), allowed=ALL_SOLVER_ORDER)
    schedule_names = _parse_ordered_names(str(cli_args.schedule_names), allowed=MAIN_SCHEDULE_ORDER)
    row_recorder = _init_row_recorder(out_root, cli_args)
    checkpoint_imports: Dict[str, Dict[str, Any]] = {}
    for dataset in datasets:
        checkpoint_info = _prepare_imported_checkpoint(
            cli_args=cli_args,
            dataset=str(dataset),
            field_network_type="transformer",
        )
        if checkpoint_info is not None:
            checkpoint_imports[str(dataset)] = checkpoint_info

    transformer_runs: List[Dict[str, Any]] = []
    for dataset in datasets:
        dataset_out_dir = out_root / str(dataset) / "transformer"
        transformer_runs.append(
            _execute_dataset_matrix(
                cli_args,
                dataset=str(dataset),
                field_network_type="transformer",
                target_nfe_values=target_nfe_values,
                solver_names=solver_names,
                schedule_names=schedule_names,
                out_dir=dataset_out_dir,
                row_recorder=row_recorder,
                checkpoint_info=checkpoint_imports.get(str(dataset)),
            )
        )

    payload = {
        "benchmark_family": "lob_conditional_generation",
        "backbone_name": "otflow",
        "pilot_mode": False,
        "comparison_mode": "solver_schedule_cross_product",
        "score_main_only": bool(cli_args.score_main_only),
        "rollout_mode": str(cli_args.rollout_mode),
        "future_block_len": (
            resolved_future_block_lens[0]
            if len(set(resolved_future_block_lens)) == 1
            else resolved_future_block_lens
        ),
        "datasets": datasets,
        "target_nfe_values": [int(v) for v in target_nfe_values],
        "solver_names": solver_names,
        "schedule_names": schedule_names,
        "tvdp_quantization_mode": _TVDP_QUANTIZATION_MODE,
        "tvdp_reference_macro_steps": int(getattr(cli_args, "tvdp_reference_macro_steps", 0)),
        "transformer_runs": transformer_runs,
        "checkpoint_imports": checkpoint_imports,
        "row_record_paths": {
            "jsonl": str(row_recorder["jsonl_path"]),
            "csv": str(row_recorder["csv_path"]),
        },
        "registry": paper_registry_snapshot(),
        "table_layout": table_layout_to_dict(build_lob_pilot_table_layout(target_nfe_values)),
        "table_stub": markdown_header_stub(build_lob_pilot_table_layout(target_nfe_values)),
        "main_table_layout": table_layout_to_dict(build_lob_table_layout(target_nfe_values)),
        "main_table_stub": markdown_header_stub(build_lob_table_layout(target_nfe_values)),
        "appendix_table_layout": table_layout_to_dict(build_lob_appendix_table_layout(target_nfe_values)),
        "appendix_table_stub": markdown_header_stub(build_lob_appendix_table_layout(target_nfe_values)),
    }
    save_json(payload, str(out_root / "lob_conditional_generation_paper_summary.json"))
    return payload


