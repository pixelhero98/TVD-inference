def _sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as fh:
        while True:
            chunk = fh.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)
    return digest.hexdigest()


def _checkpoint_record_key(
    dataset: str,
    checkpoint_id: str,
    target_nfe: int,
    solver_name: str,
    schedule_name: str,
    row_signature: Optional[str] = None,
) -> Tuple[str, str, int, str, str, Optional[str]]:
    return (
        str(dataset),
        str(checkpoint_id),
        int(target_nfe),
        str(solver_name),
        str(schedule_name),
        None if row_signature is None else str(row_signature),
    )


def _load_row_records(jsonl_path: Path) -> Dict[Tuple[str, str, int, str, str, Optional[str]], Dict[str, Any]]:
    rows: Dict[Tuple[str, str, int, str, str, Optional[str]], Dict[str, Any]] = {}
    if not jsonl_path.exists():
        return rows
    with jsonl_path.open("r", encoding="utf-8") as fh:
        for raw_line in fh:
            line = raw_line.strip()
            if not line:
                continue
            row = json.loads(line)
            key = _checkpoint_record_key(
                str(row["dataset"]),
                str(row["checkpoint_id"]),
                int(row["target_nfe"]),
                str(row["solver_name"]),
                str(row["schedule_name"]),
                None if row.get("row_signature") is None else str(row.get("row_signature")),
            )
            rows[key] = dict(row)
    return rows


def _write_row_csv(csv_path: Path, rows: Sequence[Mapping[str, Any]]) -> None:
    csv_path.parent.mkdir(parents=True, exist_ok=True)
    with csv_path.open("w", encoding="utf-8", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=list(ROW_RECORD_FIELDS))
        writer.writeheader()
        for row in rows:
            writer.writerow({field: row.get(field) for field in ROW_RECORD_FIELDS})


def _append_row_record(
    recorder: Dict[str, Any],
    row: Mapping[str, Any],
) -> Dict[str, Any]:
    normalized = dict(row)
    key = _checkpoint_record_key(
        str(normalized["dataset"]),
        str(normalized["checkpoint_id"]),
        int(normalized["target_nfe"]),
        str(normalized["solver_name"]),
        str(normalized["schedule_name"]),
        None if normalized.get("row_signature") is None else str(normalized.get("row_signature")),
    )
    if key in recorder["rows_by_key"]:
        return dict(recorder["rows_by_key"][key])
    recorder["jsonl_path"].parent.mkdir(parents=True, exist_ok=True)
    with recorder["jsonl_path"].open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(normalized) + "\n")
    recorder["rows_by_key"][key] = dict(normalized)
    recorder["row_order"].append(key)
    _write_row_csv(
        recorder["csv_path"],
        [recorder["rows_by_key"][item_key] for item_key in recorder["row_order"]],
    )
    return dict(normalized)


def _init_row_recorder(out_root: Path, cli_args: argparse.Namespace) -> Dict[str, Any]:
    jsonl_path = out_root / str(getattr(cli_args, "row_jsonl_name"))
    csv_path = out_root / str(getattr(cli_args, "row_csv_name"))
    rows_by_key = _load_row_records(jsonl_path)
    row_order = list(rows_by_key.keys())
    _write_row_csv(csv_path, [rows_by_key[item_key] for item_key in row_order])
    return {
        "jsonl_path": jsonl_path,
        "csv_path": csv_path,
        "rows_by_key": rows_by_key,
        "row_order": row_order,
    }


