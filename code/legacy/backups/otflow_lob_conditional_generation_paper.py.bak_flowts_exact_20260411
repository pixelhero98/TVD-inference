def _execute_dataset_matrix(
    cli_args: argparse.Namespace,
    *,
    dataset: str,
    field_network_type: str,
    target_nfe_values: Sequence[int],
    out_dir: Path,
    solver_names: Sequence[str],
    schedule_names: Sequence[str],
    row_recorder: Dict[str, Any],
    checkpoint_info: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    out_dir.mkdir(parents=True, exist_ok=True)
    imported_checkpoint_path = None
    checkpoint_id = f"{str(dataset)}_{str(field_network_type)}_local"
    if checkpoint_info is not None:
        imported_checkpoint_path = Path(str(checkpoint_info["imported_checkpoint_path"]))
        checkpoint_id = str(checkpoint_info["checkpoint_id"])

    model, cfg, splits, ckpt_path = _train_or_resume(
        cli_args,
        dataset,
        field_network_type,
        out_dir,
        checkpoint_path=imported_checkpoint_path,
    )
    ds_val = splits["val"]
    ds_test = splits["test"]

    eval_horizon = int(_resolved_eval_horizon(cli_args, dataset))
    val_windows = int(_resolved_eval_windows(cli_args, dataset, "val"))
    test_windows = int(_resolved_eval_windows(cli_args, dataset, "test"))
    val_window_seed = int(cli_args.seed) + 17
    test_window_seed = int(cli_args.seed) + 101
    val_generation_seed_base = int(cli_args.seed) + 1001
    test_generation_seed_base = int(cli_args.seed) + 2001
    val_metrics_seed = int(cli_args.seed) + 3001
    test_metrics_seed = int(cli_args.seed) + 4001
    latency_seed = int(cli_args.seed) + 5001

    chosen_val_t0s = _choose_valid_windows(ds_val, horizon=eval_horizon, n_windows=val_windows, seed=val_window_seed)
    chosen_test_t0s = _choose_valid_windows(ds_test, horizon=eval_horizon, n_windows=test_windows, seed=test_window_seed)

    dataset_rows: List[Dict[str, Any]] = []
    selection_details: List[Dict[str, Any]] = []
    requested_tvdp_reference_macro_steps = int(getattr(cli_args, "tvdp_reference_macro_steps", 0))
    requires_tvdp_calibration = TVDP_SCHEDULE_KEY in {str(name) for name in schedule_names}

    for target_nfe in target_nfe_values:
        solver_calibrations: Dict[str, Dict[str, Any]] = {}
        if requires_tvdp_calibration:
            for solver_key in solver_names:
                runtime_nfe = _solver_macro_steps(str(solver_key), int(target_nfe))
                solver_calibrations[str(solver_key)] = _collect_calibration(
                    model,
                    ds_val,
                    cfg,
                    horizon=int(eval_horizon),
                    macro_steps=_resolved_tvdp_reference_macro_steps(
                        int(requested_tvdp_reference_macro_steps),
                        int(runtime_nfe),
                    ),
                    n_windows=int(val_windows),
                    seed=int(val_window_seed),
                    sigma_eps=1e-6,
                    solver=str(SOLVER_RUNTIME_NAMES[str(solver_key)]),
                    chosen_t0s=[int(t0) for t0 in chosen_val_t0s.tolist()],
                    generation_seed_base=int(val_generation_seed_base),
                )

        candidate_specs = _build_schedule_matrix_specs(
            dataset=str(dataset),
            field_network_type=str(field_network_type),
            checkpoint_id=str(checkpoint_id),
            target_nfe=int(target_nfe),
            solver_names=solver_names,
            schedule_names=schedule_names,
            calibrations=solver_calibrations,
        )
        tvdp_specs_by_solver = {
            str(spec["solver_key"]): spec for spec in candidate_specs if str(spec["schedule_name"]) == TVDP_SCHEDULE_KEY
        }

        for spec_idx, spec in enumerate(candidate_specs):
            record_key = _checkpoint_record_key(
                str(dataset),
                str(checkpoint_id),
                int(target_nfe),
                str(spec["solver_name"]),
                str(spec["schedule_name"]),
                None if spec.get("row_signature") is None else str(spec.get("row_signature")),
            )
            existing_row = row_recorder["rows_by_key"].get(record_key)
            if existing_row is not None:
                dataset_rows.append(dict(existing_row))
                continue

            test_row = _run_spec(
                model=model,
                ds=ds_test,
                cfg=cfg,
                eval_horizon=int(eval_horizon),
                eval_windows=int(test_windows),
                chosen_t0s=[int(t0) for t0 in chosen_test_t0s.tolist()],
                generation_seed_base=int(test_generation_seed_base),
                metrics_seed=int(test_metrics_seed),
                score_main_only=bool(cli_args.score_main_only),
                latency_trials=int(cli_args.latency_trials),
                latency_warmup=int(cli_args.latency_warmup),
                latency_seed=int(latency_seed + spec_idx + 1000 * int(target_nfe)),
                spec=spec,
            )
            stored_row = _append_row_record(row_recorder, test_row)
            dataset_rows.append(dict(stored_row))

        selection_details.append(
            {
                "target_nfe": int(target_nfe),
                "chosen_val_t0s": [int(t0) for t0 in chosen_val_t0s.tolist()],
                "chosen_test_t0s": [int(t0) for t0 in chosen_test_t0s.tolist()],
                "solver_calibration": {
                    str(solver_key): {
                        "solver_name": str(SOLVER_RUNTIME_NAMES[str(solver_key)]),
                        "macro_steps": int(_solver_macro_steps(str(solver_key), int(target_nfe))),
                        "signal_correlations_vs_oracle": solver_calibrations[str(solver_key)].get(
                            "signal_correlations_vs_oracle",
                            {},
                        )
                        if str(solver_key) in solver_calibrations
                        else {},
                        "tvdp_params": None
                        if str(solver_key) not in tvdp_specs_by_solver
                        else {
                            "signal_trace_key": str(_TVDP_SIGNAL_TRACE_KEY),
                            "signal_family_name": str(_TVDP_SIGNAL_FAMILY_NAME),
                            "delta": float(_TVDP_DELTA),
                            "solver_order_p": float(_solver_order_p(str(solver_key))),
                            "quantization_mode": str(tvdp_specs_by_solver[str(solver_key)]["tvdp_quantization_mode"]),
                        },
                        "tvdp_reference_macro_steps": None
                        if str(solver_key) not in solver_calibrations
                        else int(solver_calibrations[str(solver_key)]["macro_steps"]),
                        "tvdp_reference_time_grid": None
                        if str(solver_key) not in solver_calibrations
                        else [float(x) for x in solver_calibrations[str(solver_key)]["reference_time_grid"]],
                        "paper_discrete_reference": None
                        if str(solver_key) not in tvdp_specs_by_solver
                        else {
                            "variants": [
                                {
                                    "schedule_name": str(TVDP_SCHEDULE_KEY),
                                    "quantization_mode": str(tvdp_specs_by_solver[str(solver_key)]["tvdp_quantization_mode"]),
                                    "indices": [int(x) for x in tvdp_specs_by_solver[str(solver_key)]["tvdp_paper_indices"]],
                                    "time_grid": [
                                        float(x) for x in tvdp_specs_by_solver[str(solver_key)]["tvdp_paper_time_grid"]
                                    ],
                                    "duplicate_count": int(
                                        tvdp_specs_by_solver[str(solver_key)]["tvdp_paper_duplicate_count"]
                                    ),
                                }
                            ]
                        },
                    }
                    for solver_key in solver_names
                },
            }
        )

    payload = {
        "benchmark_family": "lob_conditional_generation",
        "dataset": str(dataset),
        "backbone_name": "otflow",
        "field_network_type": str(field_network_type),
        "rollout_mode": str(getattr(cfg, "rollout_mode", "autoregressive")),
        "future_block_len": int(getattr(cfg, "prediction_horizon", 1)),
        "checkpoint_id": str(checkpoint_id),
        "checkpoint_path": str(ckpt_path),
        "checkpoint_provenance": None if checkpoint_info is None else dict(checkpoint_info),
        "eval_horizon": int(eval_horizon),
        "target_nfe_values": [int(v) for v in target_nfe_values],
        "solver_names": [str(name) for name in solver_names],
        "schedule_names": [str(name) for name in schedule_names],
        "tvdp_quantization_mode": _TVDP_QUANTIZATION_MODE,
        "tvdp_reference_macro_steps": int(requested_tvdp_reference_macro_steps),
        "rows": dataset_rows,
        "selection_details": selection_details,
        "row_record_paths": {
            "jsonl": str(row_recorder["jsonl_path"]),
            "csv": str(row_recorder["csv_path"]),
        },
        "registry": paper_registry_snapshot(),
        "table_layout": table_layout_to_dict(build_lob_pilot_table_layout(target_nfe_values)),
        "table_stub": markdown_header_stub(build_lob_pilot_table_layout(target_nfe_values)),
        "main_table_layout": table_layout_to_dict(build_lob_table_layout(target_nfe_values)),
        "main_table_stub": markdown_header_stub(build_lob_table_layout(target_nfe_values)),
        "appendix_table_layout": table_layout_to_dict(build_lob_appendix_table_layout(target_nfe_values)),
        "appendix_table_stub": markdown_header_stub(build_lob_appendix_table_layout(target_nfe_values)),
    }
    save_json(payload, str(out_dir / "pilot_summary.json"))
    return payload


