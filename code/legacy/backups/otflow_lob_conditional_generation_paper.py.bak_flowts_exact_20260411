def run_lob_backbone_training(cli_args: argparse.Namespace) -> Dict[str, Any]:
    if not bool(cli_args.allow_execute):
        return run_lob_prep(cli_args)

    out_root = Path(str(cli_args.out_root)).resolve()
    out_root.mkdir(parents=True, exist_ok=True)
    datasets = _parse_datasets(str(cli_args.datasets))
    runs: List[Dict[str, Any]] = []
    for dataset in datasets:
        dataset_out_dir = out_root / str(dataset) / "transformer"
        model, cfg, splits, ckpt_path = _train_or_resume(
            cli_args,
            str(dataset),
            "transformer",
            dataset_out_dir,
            checkpoint_path=None,
        )
        del model
        spec = experiment_plan_by_key()[str(dataset)]
        metadata = {
            "dataset_key": str(dataset),
            "benchmark_family": "lob_conditional_generation",
            "family_preset": "lob_shared_balanced",
            "backbone_name": "otflow",
            "field_network_type": "transformer",
            "history_len": int(cfg.history_len),
            "experiment_horizon": int(spec.experiment_horizon),
            "future_block_len": int(cfg.prediction_horizon),
            "rollout_mode": str(cfg.model.rollout_mode),
            "normalization_mode": "dataset_level_train_split_standardize",
            "time_features_enabled": bool(cfg.model.use_time_features),
            "hidden_dim": int(cfg.hidden_dim),
            "ctx_layers": int(cfg.model.ctx_layers),
            "ctx_heads": int(cfg.model.ctx_heads),
            "fu_net_layers": int(cfg.model.fu_net_layers),
            "fu_net_heads": int(cfg.model.fu_net_heads),
