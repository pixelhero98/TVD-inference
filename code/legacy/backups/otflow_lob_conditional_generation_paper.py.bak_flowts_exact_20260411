def _sample_overrides_latency(
    model: torch.nn.Module,
    cfg,
    ds,
    *,
    horizon: int,
    runtime_nfe: int,
    solver_name: str,
    time_grid: Sequence[float],
    seed: int,
    n_trials: int,
    warmup: int,
) -> Dict[str, float]:
    time_grid_override = tuple(float(x) for x in time_grid)
    backup = _apply_sample_overrides(model, cfg, solver=str(solver_name), time_grid=time_grid_override)
    try:
        return benchmark_sampling_latency(
            ds,
            model,
            cfg,
            horizon=int(horizon),
            nfe=int(runtime_nfe),
            n_trials=int(n_trials),
            warmup=int(warmup),
            seed=int(seed),
        )
    finally:
        _restore_sample_overrides(model, cfg, backup)


def _load_checkpoint_model(ckpt_path: Path, device: torch.device) -> Tuple[OTFlow, Any]:
    from config import LOBConfig

    ckpt = torch.load(str(ckpt_path), map_location="cpu", weights_only=False)
    cfg_dict = ckpt["cfg"]
    cfg = LOBConfig()
    section_types = {
        "data": type(cfg.data),
        "model": type(cfg.model),
        "fm": type(cfg.fm),
        "nf": type(cfg.nf),
        "train": type(cfg.train),
        "sample": type(cfg.sample),
    }
    for section_name, cls in section_types.items():
        section_values = dict(cfg_dict[section_name])
        if section_name == "train":
            section_values["device"] = device
        setattr(cfg, section_name, cls(**section_values))
    cfg.train.device = device

    model = OTFlow(cfg).to(device)
    model.load_state_dict(ckpt["model_state"])
    if ckpt.get("params_mean") is not None and ckpt.get("params_std") is not None:
        model.set_param_normalizer(ckpt["params_mean"], ckpt["params_std"])
    model.eval()
    return model, cfg


def _prepare_imported_checkpoint(
    *,
    cli_args: argparse.Namespace,
    dataset: str,
    field_network_type: str,
) -> Optional[Dict[str, Any]]:
    source_text = _dataset_checkpoint_source(cli_args, dataset).strip()
    if not source_text:
        return None

    source_path = Path(source_text).expanduser().resolve()
    if not source_path.exists():
        raise FileNotFoundError(f"Checkpoint source does not exist: {source_path}")

    source_sha256 = _sha256_file(source_path)
    import_root = _resolved_checkpoint_import_root(cli_args)
    import_dir = import_root / str(dataset) / str(field_network_type)
    import_dir.mkdir(parents=True, exist_ok=True)
    imported_path = import_dir / "model.pt"
    if (not imported_path.exists()) or _sha256_file(imported_path) != source_sha256:
        shutil.copy2(str(source_path), str(imported_path))

    ckpt = torch.load(str(imported_path), map_location="cpu", weights_only=False)
    cfg_dict = dict(ckpt["cfg"])
    model_cfg = dict(cfg_dict.get("model", {}))
    checkpoint_id = (
        f"{str(dataset)}_{str(field_network_type)}_"
        f"{str(model_cfg.get('rollout_mode', 'autoregressive'))}_"
        f"b{int(model_cfg.get('future_block_len', 1))}_"
        f"{source_sha256[:8]}"
    )
    provenance = {
        "checkpoint_id": checkpoint_id,
        "dataset": str(dataset),
        "backbone_name": "otflow",
        "field_network_type": str(model_cfg.get("fu_net_type", field_network_type)),
        "rollout_mode": str(model_cfg.get("rollout_mode", "autoregressive")),
        "future_block_len": int(model_cfg.get("future_block_len", 1)),
        "original_source_path": str(source_path),
        "source_sha256": source_sha256,
        "imported_checkpoint_path": str(imported_path),
    }
    metadata_path = import_dir / "checkpoint_provenance.json"
    metadata_path.write_text(json.dumps(provenance, indent=2), encoding="utf-8")
    return provenance


def _train_or_resume(
    cli_args: argparse.Namespace,
    dataset: str,
    field_network_type: str,
    out_dir: Path,
    checkpoint_path: Optional[Path] = None,
):
    out_dir.mkdir(parents=True, exist_ok=True)
    imported_ckpt_path = None if checkpoint_path is None else Path(checkpoint_path).expanduser().resolve()
    if imported_ckpt_path is not None:
        model, cfg = _load_checkpoint_model(imported_ckpt_path, device=torch.device(cli_args.device))
        dataset_args = _make_dataset_args_from_cfg(cli_args, dataset, field_network_type, cfg)
        splits = build_dataset_splits(dataset_args, cfg)
        return model, cfg, splits, imported_ckpt_path

    dataset_args = _make_dataset_args(cli_args, dataset, field_network_type)
    cfg = build_cfg_from_args(dataset_args)
    splits = build_dataset_splits(dataset_args, cfg)
    ckpt_path = out_dir / "model.pt"
    if bool(cli_args.resume) and ckpt_path.exists():
        model, cfg = _load_checkpoint_model(ckpt_path, device=torch.device(cli_args.device))
        return model, cfg, splits, ckpt_path

    seed_all(int(cli_args.seed))
    model = train_loop(
        splits["train"],
        cfg,
        model_name="otflow",
        steps=int(_resolved_train_steps(cli_args, dataset)),
        log_every=int(cli_args.log_every),
    )
    _save_checkpoint(str(ckpt_path), model, cfg, splits["train"])
    return model, cfg, splits, ckpt_path


